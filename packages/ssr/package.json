{
  "name": "@qiwi/pijma-ssr",
  "version": "0.0.0",
  "type": "module",
  "main": "./target/es5/index.js",
  "module": "./target/es6/index.js",
  "types": "./target/dts/index.d.ts",
  "exports": {
    ".": {
      "types": "./target/dts/index.d.ts",
      "import": "./target/es6/index.js",
      "require": "./target/es5/index.js"
    }
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "clean": "rimraf target node_modules",
    "build": "yarn build:all",
    "build:es5": "yarn build:swc:es5",
    "build:es6": "yarn build:swc:es6",
    "build:dts": "yarn build:tsc",
    "format": "yarn fmt",
    "lint": "yarn lint:eslint"
  },
  "files": [
    "target/dts",
    "target/es5",
    "target/es6"
  ],
  "dependencies": {
    "@emotion/server": "^11.11.0",
    "@swc/helpers": "^0.5.21"
  },
  "devDependencies": {
    "@qiwi/pijma-infra": "workspace:*"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/qiwi/pijma.git",
    "directory": "packages/ssr"
  },
  "bugs": {
    "url": "https://github.com/qiwi/pijma/issues"
  },
  "homepage": "https://github.com/qiwi/pijma/tree/master/packages/ssr#readme"
}
