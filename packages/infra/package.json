{
  "name": "@qiwi/pijma-infra",
  "description": "QIWI Pijma infra assets: common configs, dev deps, etc",
  "version": "0.0.0",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "swc.es5.json",
    "swc.es6.json"
  ],
  "scripts": {
    "build": "exit 0",
    "test": "exit 0",
    "build:all": "cd $INIT_CWD && concurrently 'npm:build:*'",
    "build:swc:es5": "cd $INIT_CWD/src/main/ts && swc . -d ../../../target/es5 --config-file $PROJECT_CWD/packages/infra/swc.es5.json && cd $INIT_CWD && tsc-esm-fix --target=target/es5 --fillBlank",
    "build:swc:es6": "cd $INIT_CWD/src/main/ts && swc . -d ../../../target/es6 --config-file $PROJECT_CWD/packages/infra/swc.es6.json && cd $INIT_CWD && tsc-esm-fix --target=target/es6 --fillBlank",
    "build:tsc": "cd $INIT_CWD && tsc --project tsconfig.dts.json",
    "lint:eslint": "cd $INIT_CWD && eslint src",
    "fmt": "cd $INIT_CWD && eslint --fix src && prettier --loglevel silent --write src"
  },
  "dependencies": {
    "@swc/cli": "0.8.1",
    "@swc/core": "1.15.24",
    "@swc/jest": "0.2.39",
    "concurrently": "8.2.2",
    "css-loader": "6.11.0",
    "eslint": "8.40.0",
    "eslint-config-prettier": "8.8.0",
    "eslint-config-qiwi": "1.17.9",
    "fast-glob": "3.3.3",
    "file-loader": "6.2.0",
    "prettier": "2.8.8",
    "prettier-config-qiwi": "1.7.3",
    "react-docgen-typescript": "patch:react-docgen-typescript@npm%3A2.2.2#~/.yarn/patches/react-docgen-typescript-npm-2.2.2-afb9698a32.patch",
    "react-styleguidist": "12.0.1",
    "react-styleguidist-visual": "patch:react-styleguidist-visual@npm%3A0.9.0#~/.yarn/patches/react-styleguidist-visual-npm-0.9.0-c05bb39789.patch",
    "style-loader": "3.3.4",
    "swc-loader": "0.2.7",
    "tsc-esm-fix": "2.20.27",
    "typescript": "4.9.5",
    "wait-on": "8.0.5",
    "webpack": "5.105.4"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/qiwi/pijma.git",
    "directory": "packages/infra"
  },
  "bugs": {
    "url": "https://github.com/qiwi/pijma/issues"
  },
  "homepage": "https://github.com/qiwi/pijma/tree/master/packages/infra#readme"
}
