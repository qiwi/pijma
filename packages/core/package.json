    "react": ">=16.14.0",
    "react-dom": ">=16.14.0"
  },
  "devDependencies": {
    "@qiwi/pijma-infra": "workspace:*",
    "@types/react": "18.0.18",
    "@types/react-dom": "18.0.6",
    "react": "18.2.0",
    "react-dom": "18.2.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/qiwi/pijma.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/qiwi/pijma/issues"
