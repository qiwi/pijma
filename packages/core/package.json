{
  "name": "@qiwi/pijma-core",
  "version": "0.0.0",
  "type": "module",
  "main": "./target/es5/index.js",
  "module": "./target/es6/index.js",
  "types": "./target/dts/index.d.ts",
  "exports": {
    ".": {
      "types": "./target/dts/index.d.ts",
      "import": "./target/es6/index.js",
      "require": "./target/es5/index.js"
    }
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "clean": "rimraf target node_modules",
    "build": "yarn build:all",
    "build:es5": "yarn build:swc:es5",
    "build:es6": "yarn build:swc:es6",
    "build:dts": "yarn build:tsc",
    "format": "yarn fmt",
    "lint": "yarn lint:eslint"
  },
  "files": [
    "target/dts",
    "target/es5",
    "target/es6"
  ],
  "dependencies": {
    "@emotion/core": "^11.0.0",
    "@emotion/css": "^11.13.5",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@swc/helpers": "^0.5.21",
    "@types/dom-helpers": "^5.0.1",
    "@types/react-google-recaptcha": "^2.1.9",
    "@types/react-overlays": "^3.1.0",
    "@types/react-transition-group": "^4.4.12",
    "dom-helpers": "^5.2.1",
    "markdown-to-jsx": "^7.7.13",
    "react-google-recaptcha": "^2.1.0",
    "react-intersection-observer": "^9.16.0",
    "react-overlays": "^5.2.1",
    "react-transition-group": "^4.4.5",
    "text-mask-core": "^5.1.2"
  },
  "peerDependencies": {
    "@types/react": ">=16.14.0",
