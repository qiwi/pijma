{
  "name": "@qiwi/pijma-desktop-extra",
  "version": "0.0.0",
  "type": "module",
  "main": "./target/es5/index.js",
  "module": "./target/es6/index.js",
  "types": "./target/dts/index.d.ts",
  "exports": {
    ".": {
      "types": "./target/dts/index.d.ts",
      "import": "./target/es6/index.js",
      "require": "./target/es5/index.js"
    }
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "clean": "rimraf target node_modules",
    "build": "yarn build:all",
    "build:es5": "yarn build:swc:es5",
    "build:es6": "yarn build:swc:es6",
    "build:dts": "yarn build:tsc",
    "test": "jest",
    "format": "yarn fmt",
    "lint": "yarn lint:eslint"
  },
  "files": [
    "target/dts",
    "target/es5",
    "target/es6"
  ],
  "dependencies": {
    "@qiwi/common-formatters": "^1.2.3",
    "@qiwi/pijma-core": "workspace:*",
    "@qiwi/pijma-desktop": "workspace:*",
    "@swc/helpers": "^0.5.21",
    "@types/react-js-pagination": "^3.0.7",
    "@types/react-table": "^7.7.20",
    "date-fns": "^2.30.0",
    "react-day-picker": "^8.10.1",
    "react-dropzone": "^14.4.1",
    "react-table": "^7.8.0"
  },
  "devDependencies": {
    "@qiwi/pijma-infra": "workspace:*",
    "@types/jest": "^29.5.14",
    "@types/react-test-renderer": "^18.0.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "react-i18next": "^11.18.6",
    "react-router": "^6.30.3",
    "react-router-dom": "^6.30.3",
    "react-test-renderer": "^18.3.1"
  },
  "peerDependencies": {
    "react-i18next": "^11.18.6"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/qiwi/pijma.git",
    "directory": "packages/desktop-extra"
  },
  "bugs": {
    "url": "https://github.com/qiwi/pijma/issues"
  },
  "homepage": "https://github.com/qiwi/pijma/tree/master/packages/desktop-extra#readme"
